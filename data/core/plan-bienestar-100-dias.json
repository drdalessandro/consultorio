          { "title": "Control de TA semanal", "description": "Auto-medición TA en domicilio con tensiómetro vinculado.", "definitionCanonical": "https://epa-bienestar.com.ar/ActivityDefinition/control-ta-semanal", "timingTiming": { "repeat": { "frequency": 1, "period": 1, "periodUnit": "wk" } } },
